# Copy this file to `.env` and fill in production values. `.env` is gitignored.
# Used by docker-compose.prod.yml via `env_file` directives.
#
# Generate a strong JWT secret: `openssl rand -base64 48`
# Generate a strong DB password: `openssl rand -base64 24`

#
# ─── Database ──────────────────────────────────────────────────────────────
#
POSTGRES_DB=rowingclub
POSTGRES_USER=rowing
POSTGRES_PASSWORD=change-me-strong-random-password

#
# ─── Backend ───────────────────────────────────────────────────────────────
#
# For first deployment use default profile (ddl-auto: update + DataSeeder runs).
# After initial schema is created, switch to "prod" (ddl-auto: validate).
#SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/rowingclub
SPRING_DATASOURCE_USERNAME=rowing
SPRING_DATASOURCE_PASSWORD=change-me-strong-random-password

# REQUIRED in prod. The app refuses to boot with the default placeholder.
# Must be a base64-encoded string of at least 32 bytes.
JWT_SECRET=change-me-generate-with-openssl-rand-base64-48

# Optional: default student booking hour (override also possible via admin UI).
STUDENT_BOOKING_HOUR=16

# Comma-separated list of allowed frontend origins (CORS).
APP_CORS_ALLOWED_ORIGINS=https://kurek.ytueks.com

# Server timezone (Istanbul for this deployment).
TZ=Europe/Istanbul
JAVA_TOOL_OPTIONS=-Duser.timezone=Europe/Istanbul

# Optional: Sentry DSN for error reporting. Leave empty to disable.
# Backend reports server-side 5xx errors; frontend reports client exceptions.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Retention window for nightly pg_dump sidecar (days). Default 14.
BACKUP_RETENTION_DAYS=14

#
#
# ─── Frontend ──────────────────────────────────────────────────────────────
# IMPORTANT: NEXT_PUBLIC_API_URL is baked into the JS bundle at build time.
# Set it as a build arg (`docker compose build --build-arg NEXT_PUBLIC_API_URL=...`)
# or in this .env file before running `docker compose build`.
# For local dev with docker compose: http://localhost:8081/api
# For production (single-domain setup): https://kurek.ytueks.com/api
NEXT_PUBLIC_API_URL=https://kurek.ytueks.com/api
